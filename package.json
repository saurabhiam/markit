{
  "name": "markit-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "overrides": {
    "@markitjs/core": "workspace:*",
    "@markitjs/react": "workspace:*",
    "@markitjs/angular": "workspace:*"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "dev": "turbo run dev",
    "clean": "turbo run clean",
    "typecheck": "turbo run typecheck",
    "e2e": "turbo run e2e",
    "docs:dev": "turbo run dev --filter=@markitjs/docs",
    "docs:build": "turbo run build --filter=@markitjs/docs",
    "bench": "turbo run bench",
    "size": "./scripts/bundle-size.sh",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "changeset publish --no-git-tag",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2",
    "@vitest/browser": "^3",
    "jsdom": "^26",
    "prettier": "^3",
    "turbo": "^2",
    "typescript": "^5.7",
    "vitest": "^3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.10"
}
