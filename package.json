{
  "name": "markit-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "dev": "turbo run dev",
    "clean": "turbo run clean",
    "typecheck": "turbo run typecheck",
    "e2e": "turbo run e2e",
    "docs:dev": "turbo run dev --filter=@markit/docs",
    "docs:build": "turbo run build --filter=@markit/docs",
    "bench": "turbo run e2e --filter=@markit/e2e-bench"
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5.7",
    "@changesets/cli": "^2",
    "vitest": "^3",
    "@vitest/browser": "^3",
    "jsdom": "^26",
    "prettier": "^3"
  },
  "packageManager": "bun@1.3.10"
}
