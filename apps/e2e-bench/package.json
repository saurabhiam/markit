{
  "name": "@markitjs/e2e-bench",
  "version": "0.0.1",
  "private": true,
  "description": "Playwright performance benchmarks and e2e smoke tests (highlight-api, dom, overlay) for @markitjs/core",
  "type": "module",
  "scripts": {
    "bench": "playwright test",
    "bench:headed": "playwright test --headed",
    "e2e": "playwright test --grep \"1000 nodes\"",
    "playwright:install": "playwright install chromium --with-deps"
  },
  "devDependencies": {
    "@playwright/test": "^1",
    "serve": "^14"
  }
}
