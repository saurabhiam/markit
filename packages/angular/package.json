{
  "name": "@markitjs/angular",
  "version": "1.0.3",
  "description": "Angular bindings for @markitjs/core text highlighting engine",
  "type": "module",
  "main": "./dist/fesm2022/markitjs-angular.mjs",
  "module": "./dist/fesm2022/markitjs-angular.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/fesm2022/markitjs-angular.mjs",
      "default": "./dist/fesm2022/markitjs-angular.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "ng-packagr -p ng-package.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "peerDependencies": {
    "@markitjs/core": ">=1.0.4",
    "@angular/core": "^17.0.0 || ^18.0.0 || ^19.0.0 || ^20.0.0 || ^21.0.0",
    "@angular/common": "^17.0.0 || ^18.0.0 || ^19.0.0 || ^20.0.0 || ^21.0.0"
  },
  "devDependencies": {
    "@markitjs/core": "workspace:*",
    "@analogjs/vite-plugin-angular": "^1",
    "@analogjs/vitest-angular": "^1",
    "@angular/build": "^19",
    "@angular/common": "^19",
    "@angular/compiler": "^19",
    "@angular/compiler-cli": "^19",
    "@angular/core": "^19",
    "@angular/platform-browser": "^19",
    "@angular/platform-browser-dynamic": "^19",
    "ng-packagr": "^19.0.0",
    "rxjs": "^7",
    "typescript": "~5.8.0",
    "vite": "^6",
    "vitest": "^3",
    "zone.js": "^0.15"
  },
  "keywords": [
    "highlight",
    "search",
    "text",
    "mark",
    "angular",
    "directive"
  ],
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saurabhiam/markit.git",
    "directory": "packages/angular"
  },
  "homepage": "https://saurabhiam.github.io/markit/",
  "bugs": "https://github.com/saurabhiam/markit/issues"
}
