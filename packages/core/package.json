{
  "name": "@markitjs/core",
  "version": "1.0.2",
  "description": "High-performance text highlighting engine with CSS Highlight API and DOM Range rendering",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5.7",
    "vitest": "^3",
    "jsdom": "^26"
  },
  "keywords": [
    "highlight",
    "search",
    "text",
    "mark",
    "find"
  ],
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/saurabhiam/markit.git",
    "directory": "packages/core"
  },
  "homepage": "https://saurabhiam.github.io/markit/",
  "bugs": "https://github.com/saurabhiam/markit/issues"
}
